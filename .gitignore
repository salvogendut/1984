*~
bin/
disks/
*.o
*.dsk
*.sna

# Bundled ROMs (CPC firmware + open-source M4ROM/diag) are tracked.
# Ignore everything else under roms/ so user-dropped binaries stay local.
roms/*
!roms/*.ROM
!roms/*.rom
!roms/README*

# dist tarballs produced by `make dist`
/1984-*.tar.gz

# Windows build output dirs (CI artifacts cover these now)
/dist-win*/

# autotools — generated by ./configure or make, not committed
/Makefile
/config.status
/config.log
/src/.deps/
/src/.dirstamp
/1984
/autom4te.cache/

# Personal notes / scratch — never commit
dimitri-note*.md
notes/
*.note.md

# Runtime screenshots from --screenshot-at and overlay capture
1984_*.ppm
1984_*.png

# Flatpak build output
/flatpak-repo/
/1984.flatpak

# Autotools regenerable bits not tracked elsewhere
/build-aux/config.guess
/build-aux/config.sub
/config.h.in
